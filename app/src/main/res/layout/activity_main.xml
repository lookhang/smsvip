<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#22000000"
            android:padding="12dp"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="规则设置（关键词 / 号码）" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高级设置（铃声 / 强度）" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartMonitor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开启后台监控" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试提醒" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="权限与系统设置（务必开启）"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantSms"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="授予短信权限" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrantNotif"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="授予通知权限" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBattery"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="电池无限制（关掉省电）" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOverlay"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="授予悬浮窗（可选）" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAutostart"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="小米：开启自启动" />

        <TextView
            android:id="@+id/tvGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#22000000"
            android:minHeight="48dp"
            android:padding="12dp"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
